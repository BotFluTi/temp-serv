@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Temperature Monitor</h1>

    <h2>
        Current temperature: @ViewBag.Temperature °C
    </h2>

    <h3>
        Read at:
        @if (ViewBag.ReadAt == null)
        {
            <span>No date yet</span>
        }
        else
        {
            <span>@(((DateTime)ViewBag.ReadAt).ToString("dd.MM.yyyy HH:mm:ss"))</span>
        }
    </h3>

    <button onclick="location.reload()">Refresh</button>
</div>

<hr />

<div style="max-width: 900px; margin: 30px auto;">
    <h2 class="text-center">Temperature History</h2>
    <canvas id="temperatureChart"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    async function loadTemperatureChart() {
        const response = await fetch('/api/data/history');
        const readings = await response.json();

        const orderedReadings = readings.reverse();

        const labels = orderedReadings.map(item => {
            const date = new Date(item.readAt);
            return date.toLocaleTimeString();
        });

        const temperatures = orderedReadings.map(item => item.temperature);

        const ctx = document.getElementById('temperatureChart');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Temperature °C',
                    data: temperatures,
                    tension: 0.3,
                    fill: false
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        title: {
                            display: true,
                            text: 'Temperature °C'
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Reading time'
                        }
                    }
                }
            }
        });
    }

    loadTemperatureChart();

    setTimeout(() => location.reload(), 5000);
</script>